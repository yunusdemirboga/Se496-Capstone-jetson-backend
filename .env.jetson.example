# Copy this file to .env and fill in your values:
#   cp .env.jetson.example .env

# WebSocket URL of the backend (running on your laptop)
BACKEND_WS_URL=ws://LAPTOP_IP:8000/ws/detections

# UUID of this Jetson's base station record in the database.
# Create one via POST /base_stations/ first, then paste the returned id here.
BASE_STATION_ID=your-base-station-uuid-here

# Supabase credentials (same values as backend/.env)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=your-bucket-name

# How long Supabase signed URLs remain valid (seconds). Match backend setting.
SIGNED_URL_EXPIRY_SECONDS=3600

# OpenAI API key for GPT-4o-mini descriptions.
# Leave blank or use --no-gpt flag to skip GPT calls.
OPENAI_API_KEY=sk-...
